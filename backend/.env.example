EBOOK_DATABASE_URL=postgresql+psycopg://ebook:password@localhost:5432/ebook
EBOOK_SECRET_KEY=replace-with-a-long-random-secret
EBOOK_COOKIE_SECURE=true
EBOOK_STORAGE_DIR=./storage
EBOOK_SUPERADMIN_USERNAME=admin
EBOOK_SUPERADMIN_PASSWORD=replace-with-a-strong-password
